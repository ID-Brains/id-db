---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import Searchbar from "../components/searchbar.astro";

const docs = (await getCollection("docs")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const subjectsCount = new Set(docs.map((doc) => doc.data.subject)).size;

---

<MainLayout title="College Knowledge Base | All Docs">
    <section class="px-8 md:px-24 py-20 md:py-24 bg-surface-container-low border-b border-outline-variant/25">
      <p class="font-label text-xs uppercase tracking-[0.3em] text-primary mb-5 opacity-80">Knowledge Base Library</p>
      <h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter text-on-surface mb-6 leading-[0.95]">All Docs</h1>
      <p class="text-on-surface-variant text-lg max-w-3xl leading-relaxed">
        Browse student-contributed lecture notes, summaries, and practical reports by subject, year, and term.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-8">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" data-icon="description">description</span>
          <div>
            <p class="font-headline text-2xl font-bold leading-none">{docs.length}</p>
            <p class="font-label text-[11px] uppercase tracking-wider text-on-surface-variant">Documents</p>
          </div>
        </div>
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" data-icon="category">category</span>
          <div>
            <p class="font-headline text-2xl font-bold leading-none">{subjectsCount}</p>
            <p class="font-label text-[11px] uppercase tracking-wider text-on-surface-variant">Subjects</p>
          </div>
        </div>
      </div>

      <div class="mt-10 max-w-4xl rounded-2xl border border-outline-variant/20 bg-surface-container-lowest/90 p-5 md:p-6 shadow-[0_12px_36px_rgba(15,23,42,0.08)]">
        <p class="mb-3 font-label text-[11px] uppercase tracking-[0.2em] text-on-surface-variant">Quick Search</p>
        <Searchbar />
      </div>
    </section>

    <section class="px-8 md:px-24 py-16 md:py-20 bg-surface">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {docs.map((doc) => (
          <article
            class="bg-surface-container-lowest rounded-xl p-6 border border-outline-variant/15 hover:border-primary/40 hover:bg-surface-bright transition-all scroll-mt-24"
            id={`doc-${doc.id.replace(/[^a-zA-Z0-9-]/g, "-")}`}
            data-search-card
            data-search-title={doc.data.title}
            data-search-excerpt={doc.data.description}
            data-search-subject={doc.data.subject}
            data-search-prof={doc.data.prof}
            data-search-contributor={doc.data.contributor}
            data-search-tags={doc.data.tags.join(" ")}
          >
            <div class="mb-4 flex items-center justify-between gap-4">
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-secondary-container text-on-secondary-container text-[11px] font-label font-bold uppercase tracking-wide">
                {doc.data.subject}
              </span>
              <span class="text-xs text-on-surface-variant font-label uppercase tracking-wider">Year {doc.data.year} • T{doc.data.term}</span>
            </div>

            <h2 class="font-headline text-2xl font-bold tracking-tight text-primary mb-3">{doc.data.title}</h2>
            <p class="text-sm text-on-surface-variant leading-relaxed mb-5">{doc.data.description}</p>

            <div class="space-y-2 text-sm">
              <p class="text-on-surface-variant"><span class="font-semibold text-on-surface">Professor:</span> {doc.data.prof}</p>
              <p class="text-on-surface-variant"><span class="font-semibold text-on-surface">Contributor:</span> {doc.data.contributor}</p>
              <p class="text-on-surface-variant"><span class="font-semibold text-on-surface">Date:</span> {doc.data.date.toLocaleDateString("en-GB")}</p>
            </div>

            <div class="mt-5 flex flex-wrap gap-2">
              {doc.data.tags.map((tag) => (
                <span class="px-2.5 py-1 rounded-full bg-surface-container text-on-surface-variant text-[11px] font-label uppercase tracking-wide">
                  {tag}
                </span>
              ))}
              <span class="px-2.5 py-1 rounded-full bg-tertiary-container text-on-tertiary-container text-[11px] font-label uppercase tracking-wide">
                {doc.data.language.toUpperCase()}
              </span>
            </div>
          </article>
        ))}
      </div>
    </section>
</MainLayout>
