---
import MainLayout from "../layouts/MainLayout.astro";
import AppearanceWidget from "../components/AppearanceWidget.astro";
---

<MainLayout title="Tests | project-hikma">
  <header class="relative min-h-[70vh] flex flex-col justify-center px-8 md:px-24 bg-surface overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-1/2 h-1/2 opacity-5 pointer-events-none bg-[radial-gradient(ellipse_at_bottom_left,_var(--tw-gradient-stops))] from-primary to-transparent"></div>

    <div class="grid grid-cols-12 gap-8 relative z-10">
      <div class="col-span-12 lg:col-span-9 xl:col-span-8">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-container text-on-primary-container text-xs font-label font-bold mb-6 border border-primary/20">
          <span class="material-symbols-outlined text-sm" data-icon="rule">rule</span>
          TESTS FORMAT GUIDE
        </div>
        <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-bold tracking-tighter text-on-surface mb-8 leading-[1.05]">
          Upload Questions With <span class="text-primary">Strict Validation.</span>
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl max-w-3xl mb-10 leading-relaxed">
          This page explains the exact markdown structure accepted by our parser. If your file follows these rules, it will pass validation consistently.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            class="bg-primary text-on-primary px-8 py-4 rounded-xl font-medium text-lg hover:bg-primary/90 hover:shadow-lg hover:shadow-primary/20 transition-all active:scale-95 flex items-center justify-center gap-3"
            href="#schema"
          >
            <span class="material-symbols-outlined" data-icon="fact_check">fact_check</span>
            Read Schema Rules
          </a>
          <a
            class="bg-surface-container border border-outline text-on-surface px-8 py-4 rounded-xl font-medium text-lg hover:bg-surface-container-high hover:border-outline-variant transition-all active:scale-95 flex items-center justify-center gap-3"
            href="#ai-prompt"
          >
            <span class="material-symbols-outlined" data-icon="smart_toy">smart_toy</span>
            Copy AI Prompt
          </a>
        </div>
      </div>
    </div>
  </header>

  <section id="schema" class="px-8 md:px-24 py-24 bg-surface">
    <div class="mb-14 max-w-3xl">
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight mb-6 text-on-surface">Required Question Schema</h2>
      <p class="text-xl text-on-surface-variant leading-relaxed">
        Each question should be a short markdown block.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <div class="bg-surface-container-low rounded-3xl p-8 border border-outline/10">
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Fields</h3>
        <ul class="space-y-3 text-on-surface-variant">
          <li><span class="font-semibold text-on-surface">Question</span>: one paragraph after the heading</li>
          <li><span class="font-semibold text-on-surface">Options</span>: one bullet list with 4 items</li>
          <li><span class="font-semibold text-on-surface">Answer</span>: a paragraph starting with <code>Answer:</code> or <code>Correct answer:</code></li>
          <li><span class="font-semibold text-on-surface">Explanation</span>: optional, starts with <code>Explanation:</code></li>
        </ul>
      </div>

      <div class="bg-surface-container-low rounded-3xl p-8 border border-outline/10">
        <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Validation Rules</h3>
        <ul class="space-y-3 text-on-surface-variant">
          <li>Use a heading to start each question.</li>
          <li>Put the question text first, then the options.</li>
          <li>Keep the answer text identical to one option.</li>
          <li>Add an explanation only if needed.</li>
        </ul>
      </div>
    </div>

    <div class="bg-surface-container-low rounded-3xl p-8 md:p-10 border border-outline/10">
      <h3 class="font-headline text-2xl font-bold text-on-surface mb-4">Strict File Rules</h3>
      <ol class="list-decimal pl-6 space-y-3 text-on-surface-variant">
          <li>Start each question with a heading.</li>
          <li>Put the question in the first paragraph.</li>
          <li>Use one bullet list for the choices.</li>
          <li>Write the answer on its own line with <strong>Answer:</strong> or <strong>Correct answer:</strong>.</li>
          <li>Optional: add an explanation line with <strong>Explanation:</strong>.</li>
      </ol>
    </div>
  </section>

  <section class="py-20 px-8 md:px-24 bg-surface-container-lowest border-y border-outline-variant/20">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-headline text-3xl md:text-4xl font-bold text-on-surface mb-6">Valid Example</h2>
      <p class="text-on-surface-variant mb-6">Use this markdown format when preparing your questions file.</p>
      <pre class="bg-surface-container text-on-surface rounded-2xl p-6 overflow-x-auto border border-outline/20"><code>{`## Question 1

What is 2 + 2?

- 1
- 2
- 3
- 4

Answer: 4
Explanation: 2 + 2 equals 4.

## Question 2

Capital of Germany?

- Berlin
- Madrid
- Paris
- Rome

Correct answer: Berlin`}</code></pre>
    </div>
  </section>

  <section id="ai-prompt" class="px-8 md:px-24 py-24 bg-surface">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-headline text-4xl md:text-5xl font-bold tracking-tight mb-6 text-on-surface">AI Prompt for Conversion</h2>
      <p class="text-xl text-on-surface-variant mb-8 leading-relaxed">
        Paste your questions here and return only the same markdown style.
      </p>
      <div class="flex justify-end mb-3">
        <button
          type="button"
          class="inline-flex items-center gap-2 bg-surface-container border border-outline text-on-surface px-4 py-2 rounded-lg font-medium hover:bg-surface-container-high transition-colors"
          data-copy-prompt-button
          aria-label="Copy AI prompt"
        >
          <span class="material-symbols-outlined text-base" data-icon="content_copy">content_copy</span>
          <span data-copy-prompt-label>Copy prompt</span>
        </button>
      </div>
      <pre class="bg-surface-container text-on-surface rounded-2xl p-6 overflow-x-auto border border-outline/20"><code data-copy-prompt-source>{`Convert the following questions into the markdown format accepted by the quiz parser.

Output requirements:
    1) Return plain markdown only
    2) Use a heading, a question paragraph, and one bullet list
    3) Add an answer line that starts with Answer: or Correct answer:
    4) Add an explanation line only if needed
    5) Keep the answer text identical to one of the options
    6) Do not wrap the result in a code fence or add commentary

Return markdown only.


Input content:
<PASTE YOUR QUESTIONS HERE>`}</code></pre>
    </div>
  </section>

  <script>
    const copyButton = document.querySelector('[data-copy-prompt-button]');
    const promptSource = document.querySelector('[data-copy-prompt-source]');
    const copyLabel = document.querySelector('[data-copy-prompt-label]');

    if (copyButton instanceof HTMLButtonElement && promptSource instanceof HTMLElement && copyLabel instanceof HTMLElement) {
      copyButton.addEventListener('click', async () => {
        const promptText = promptSource.textContent ?? '';
        const defaultLabel = 'Copy prompt';

        try {
          await navigator.clipboard.writeText(promptText);
          copyLabel.textContent = 'Copied';
          setTimeout(() => {
            copyLabel.textContent = defaultLabel;
          }, 1600);
        } catch {
          copyLabel.textContent = 'Copy failed';
          setTimeout(() => {
            copyLabel.textContent = defaultLabel;
          }, 1600);
        }
      });
    }
  </script>

  <section class="bg-surface-container py-20 px-8 md:px-24">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-headline text-3xl md:text-4xl font-bold mb-8 text-on-surface">Pre-Upload Checklist</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-surface rounded-2xl p-6 border border-outline/10 text-on-surface-variant">Use markdown headings and keep each block self-contained.</div>
        <div class="bg-surface rounded-2xl p-6 border border-outline/10 text-on-surface-variant">Options array has exactly 4 entries.</div>
        <div class="bg-surface rounded-2xl p-6 border border-outline/10 text-on-surface-variant">Answer is an integer from 0 to 3.</div>
        <div class="bg-surface rounded-2xl p-6 border border-outline/10 text-on-surface-variant">Explanation, when present, must be non-empty.</div>
      </div>
    </div>
  </section>
