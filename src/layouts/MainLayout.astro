---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "College Knowledge Base" } = Astro.props;
---

<!DOCTYPE html>

<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{title}</title>

  <script is:inline>
    (() => {
      const root = document.documentElement;
      const savedTheme = localStorage.getItem('theme');
      const savedSize = localStorage.getItem('text-size');
      const savedSpacing = localStorage.getItem('line-spacing');

      const sizeMap = { small: '14px', medium: '16px', large: '19px' };
      const spacingMap = { tight: '1.35', medium: '1.6', wide: '1.9' };
      const headingSpacingMap = { tight: '1.1', medium: '1.2', wide: '1.25' };

      if (savedTheme === 'light' || savedTheme === 'dark') {
        root.dataset.theme = savedTheme;
        root.classList.toggle('dark', savedTheme === 'dark');
      } else {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        root.dataset.theme = prefersDark ? 'dark' : 'light';
        root.classList.toggle('dark', prefersDark);
      }

      const appliedSize = savedSize === 'small' || savedSize === 'medium' || savedSize === 'large' ? savedSize : 'medium';
      root.style.fontSize = sizeMap[appliedSize];
      root.style.setProperty('--app-font-size', sizeMap[appliedSize]);

      const appliedSpacing = savedSpacing === 'tight' || savedSpacing === 'medium' || savedSpacing === 'wide' ? savedSpacing : 'medium';
      root.style.lineHeight = spacingMap[appliedSpacing];
      root.style.setProperty('--app-line-height', spacingMap[appliedSpacing]);
      root.style.setProperty('--app-line-height-headings', headingSpacingMap[appliedSpacing]);
    })();
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body class="font-body bg-surface text-on-surface flex min-h-screen flex-col" data-app-root>
  <Navbar />

  <main class="flex-grow pt-16">
    <slot />
  </main>

  <footer class="w-full bg-surface-container-low border-t border-outline-variant/40 mt-auto flex flex-col md:flex-row justify-between items-center px-12 py-8 gap-4 font-label text-xs uppercase tracking-widest">
    <div class="text-on-surface-variant">College Knowledge Base. Curated by students for students.</div>
    <div class="flex items-center gap-8">
      <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Privacy Policy</a>
      <a class="text-on-surface-variant hover:text-primary transition-colors" href="#">Terms of Use</a>
      <a class="text-on-surface-variant hover:text-primary transition-colors" href="/docs">Documentation</a>
    </div>
  </footer>
</body>
</html>
