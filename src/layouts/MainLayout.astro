---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "project-hikma" } = Astro.props;
---

<!DOCTYPE html>

<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/id-db/Hikma_icon.svg" />

  <script>
    import { applyStoredAppearance } from "../scripts/appearance";

    applyStoredAppearance();
    document.addEventListener("astro:page-load", applyStoredAppearance);
  </script>

  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;family=Inter:wght@300;400;500;600;700&amp;family=Manrope:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body class="font-body bg-surface text-on-surface flex min-h-screen flex-col" data-app-root>
  <Navbar />

  <main class="flex-grow pt-16">
    <slot />
  </main>

  <footer class="w-full bg-surface-container-low border-t border-outline-variant/40 mt-auto flex flex-col md:flex-row justify-between items-center px-12 py-8 gap-4 font-label text-xs uppercase tracking-widest">
    <div class="text-on-surface-variant">project-hikma. Curated by students for students.</div>
    <div class="flex items-center gap-8">
      <a class="text-on-surface-variant hover:text-primary transition-colors" href={`https://github.com/ID-Brains/id-db/tree/main/docs`}>Documentation</a>
    </div>
  </footer>
</body>
</html>
