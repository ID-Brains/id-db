---
---

<div class="relative inline-flex items-center" data-theme-dropdown>
  <button
    type="button"
    class="inline-flex h-10 min-w-10 cursor-pointer items-center justify-center gap-1 rounded-full border border-outline-variant/70 bg-surface-container-lowest/90 px-3 text-on-surface shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition-all duration-150 hover:-translate-y-px hover:border-primary/45 hover:shadow-[0_12px_26px_rgba(15,23,42,0.12)]"
    aria-label="Open appearance settings"
    aria-haspopup="dialog"
    aria-expanded="false"
    aria-controls="theme-dropdown-panel"
    data-theme-dropdown-trigger
  >
    <span class="text-base leading-none text-primary" aria-hidden="true">☾</span>
    <span class="text-xs leading-none text-on-surface-variant" aria-hidden="true">▾</span>
  </button>

  <div class="absolute right-0 top-[calc(100%+0.75rem)] z-[60] w-[min(22.5rem,calc(100vw-1rem))] rounded-[1.25rem] border border-outline-variant/70 bg-surface-container-lowest/95 p-[1.1rem] shadow-[0_24px_60px_rgba(15,23,42,0.18)] backdrop-blur-[18px] max-[480px]:w-[min(22rem,calc(100vw-1rem))]" id="theme-dropdown-panel" hidden data-theme-dropdown-panel>
    <section class="mb-4 border-b border-outline-variant/60 pb-4 last:mb-0 last:border-b-0 last:pb-0">
      <h2 class="mb-3 text-right text-sm font-bold tracking-[0.02em] text-primary">Text Size</h2>
      <div class="grid grid-cols-3 gap-[0.65rem]" role="radiogroup" aria-label="Text size">
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-text-size="small" aria-pressed="false">
          <span class="text-[1.45rem] leading-none font-bold text-primary">A</span>
          <span class="text-[0.8rem] leading-none font-semibold">Small</span>
        </button>
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-text-size="medium" aria-pressed="true">
          <span class="text-[1.9rem] leading-none font-bold text-primary">A</span>
          <span class="text-[0.8rem] leading-none font-semibold">Medium</span>
        </button>
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-text-size="large" aria-pressed="false">
          <span class="text-[2.2rem] leading-none font-bold text-primary">A</span>
          <span class="text-[0.8rem] leading-none font-semibold">Large</span>
        </button>
      </div>
    </section>

    <section class="mb-4 border-b border-outline-variant/60 pb-4 last:mb-0 last:border-b-0 last:pb-0">
      <h2 class="mb-3 text-right text-sm font-bold tracking-[0.02em] text-primary">Color Theme</h2>
      <div class="grid grid-cols-3 gap-[0.65rem]" role="radiogroup" aria-label="Color theme">
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-theme="light" aria-pressed="true">
          <span class="h-[1.45rem] w-[2.1rem] rounded-[0.35rem] border border-outline-variant/90 bg-surface-container-lowest"></span>
          <span class="text-[0.8rem] leading-none font-semibold">Light</span>
        </button>
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-theme="dark" aria-pressed="false">
          <span class="h-[1.45rem] w-[2.1rem] rounded-[0.35rem] border border-outline-variant/90 bg-inverse-surface"></span>
          <span class="text-[0.8rem] leading-none font-semibold">Dark</span>
        </button>
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-theme="system" aria-pressed="false">
          <span class="h-[1.45rem] w-[2.1rem] rounded-[0.35rem] border border-outline-variant/90 bg-[linear-gradient(135deg,var(--color-surface-container-lowest)_50%,var(--color-inverse-surface)_50%)]"></span>
          <span class="text-[0.8rem] leading-none font-semibold">System</span>
        </button>
      </div>
    </section>

    <section class="mb-4 border-b border-outline-variant/60 pb-4 last:mb-0 last:border-b-0 last:pb-0">
      <h2 class="mb-3 text-right text-sm font-bold tracking-[0.02em] text-primary">Line Spacing</h2>
      <div class="grid grid-cols-3 gap-[0.65rem]" role="radiogroup" aria-label="Line spacing">
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-spacing="wide" aria-pressed="false">
          <span class="flex h-4 w-8 flex-col justify-between">
            <span class="h-0.5 rounded-full bg-primary"></span>
            <span class="h-0.5 rounded-full bg-primary"></span>
            <span class="h-0.5 rounded-full bg-primary"></span>
          </span>
          <span class="text-[0.8rem] leading-none font-semibold">Wide</span>
        </button>
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-spacing="medium" aria-pressed="true">
          <span class="flex h-4 w-8 flex-col justify-center gap-[0.34rem]">
            <span class="h-0.5 rounded-full bg-primary"></span>
            <span class="h-0.5 rounded-full bg-primary"></span>
          </span>
          <span class="text-[0.8rem] leading-none font-semibold">Medium</span>
        </button>
        <button type="button" class="appearance-none rounded-[0.8rem] border border-outline-variant/80 bg-surface px-[0.55rem] py-3 text-on-surface min-h-[4.8rem] flex cursor-pointer flex-col items-center justify-center gap-[0.3rem] transition-all duration-150 hover:-translate-y-px hover:border-primary/40 aria-pressed:border-primary aria-pressed:ring-1 aria-pressed:ring-primary/25" data-spacing="tight" aria-pressed="false">
          <span class="flex h-4 w-8 flex-col justify-center">
            <span class="h-0.5 rounded-full bg-primary"></span>
          </span>
          <span class="text-[0.8rem] leading-none font-semibold">Tight</span>
        </button>
      </div>
    </section>

  </div>
</div>

<script>
  // @ts-nocheck
  const dropdownRoot = document.querySelector('[data-theme-dropdown]');

  if (!dropdownRoot) {
    throw new Error('Theme dropdown was not found');
  }

  const trigger = dropdownRoot.querySelector('[data-theme-dropdown-trigger]');
  const panel = dropdownRoot.querySelector('[data-theme-dropdown-panel]');

  if (!trigger || !panel) {
    throw new Error('Theme dropdown elements are missing');
  }

  const themeButtons = dropdownRoot.querySelectorAll('[data-theme]');
  const sizeButtons = dropdownRoot.querySelectorAll('[data-text-size]');
  const spacingButtons = dropdownRoot.querySelectorAll('[data-spacing]');

  const rootElement = document.documentElement;
  const themeKey = 'theme';
  const textSizeKey = 'text-size';
  const spacingKey = 'line-spacing';

  const textSizeMap = {
    small: '15px',
    medium: '16px',
    large: '18px',
  };

  const spacingMap = {
    tight: '1.5',
    medium: '2',
    wide: '2.5',
  };

  const setButtonGroupState = (
    buttons,
    attributeName,
    activeValue,
  ) => {
    buttons.forEach((button) => {
      const isActive = button.getAttribute(attributeName) === activeValue;
      button.setAttribute('aria-pressed', String(isActive));
    });
  };

  const setTheme = (theme) => {
    if (theme === 'system') {
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      rootElement.classList.toggle('dark', prefersDark);
      localStorage.removeItem(themeKey);
      return;
    }

    rootElement.classList.toggle('dark', theme === 'dark');
    localStorage.setItem(themeKey, theme);
  };

  const syncThemeButtons = (activeTheme) => {
    setButtonGroupState(themeButtons, 'data-theme', activeTheme);
  };

  const applyThemePreference = (theme) => {
    setTheme(theme);
    syncThemeButtons(theme);
  };

  const applyTextSize = (size) => {
    rootElement.style.setProperty('--app-font-size', textSizeMap[size]);
    localStorage.setItem(textSizeKey, size);
    setButtonGroupState(sizeButtons, 'data-text-size', size);
  };

  const applySpacing = (spacing) => {
    rootElement.style.setProperty('--app-line-height', spacingMap[spacing]);
    localStorage.setItem(spacingKey, spacing);
    setButtonGroupState(spacingButtons, 'data-spacing', spacing);
  };

  const loadStoredTheme = () => {
    const savedTheme = localStorage.getItem(themeKey);
    if (savedTheme === 'light' || savedTheme === 'dark') {
      applyThemePreference(savedTheme);
      return;
    }

    applyThemePreference('system');
  };

  const loadStoredTextSize = () => {
    const savedSize = localStorage.getItem(textSizeKey);
    if (savedSize === 'small' || savedSize === 'medium' || savedSize === 'large') {
      applyTextSize(savedSize);
      return;
    }

    applyTextSize('medium');
  };

  const loadStoredSpacing = () => {
    const savedSpacing = localStorage.getItem(spacingKey);
    if (savedSpacing === 'tight' || savedSpacing === 'medium' || savedSpacing === 'wide') {
      applySpacing(savedSpacing);
      return;
    }

    applySpacing('medium');
  };

  const openDropdown = () => {
    panel.hidden = false;
    trigger.setAttribute('aria-expanded', 'true');
  };

  const closeDropdown = () => {
    panel.hidden = true;
    trigger.setAttribute('aria-expanded', 'false');
  };

  trigger.addEventListener('click', () => {
    if (panel.hidden) {
      openDropdown();
      return;
    }

    closeDropdown();
  });

  dropdownRoot.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) {
      return;
    }

    const themeButton = target.closest('[data-theme]');
    if (themeButton) {
      const theme = themeButton.getAttribute('data-theme');
      if (theme === 'light' || theme === 'dark' || theme === 'system') {
        applyThemePreference(theme);
      }
      return;
    }

    const textSizeButton = target.closest('[data-text-size]');
    if (textSizeButton) {
      const size = textSizeButton.getAttribute('data-text-size');
      if (size === 'small' || size === 'medium' || size === 'large') {
        applyTextSize(size);
      }
      return;
    }

    const spacingButton = target.closest('[data-spacing]');
    if (spacingButton) {
      const spacing = spacingButton.getAttribute('data-spacing');
      if (spacing === 'tight' || spacing === 'medium' || spacing === 'wide') {
        applySpacing(spacing);
      }
      return;
    }

  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Node)) {
      return;
    }

    if (!dropdownRoot.contains(target)) {
      closeDropdown();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeDropdown();
      trigger.focus();
    }
  });

  const prefersDarkMode = window.matchMedia('(prefers-color-scheme: dark)');
  prefersDarkMode.addEventListener('change', () => {
    if (localStorage.getItem(themeKey) === null) {
      applyThemePreference('system');
    }
  });

  loadStoredTextSize();
  loadStoredSpacing();
  loadStoredTheme();
</script>
