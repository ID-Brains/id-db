---
import { getCollection } from "astro:content";
import { LinkCard, CardGrid } from "@astrojs/starlight/components";

interface Props {
    level: number;
    term: number;
}

const { level, term } = Astro.props;

const allDocs = await getCollection("docs");
const excludedSubjects = new Set(["documentation"]);

const termDocs = allDocs.filter(
    (doc) =>
        doc.data.level === level &&
        doc.data.term === term &&
        !excludedSubjects.has(doc.data.subject) &&
        !doc.id.endsWith("index") &&
        doc.id !== "docs" &&
        doc.id !== "404",
);

const grouped = new Map<string, typeof termDocs>();
for (const doc of termDocs) {
    const key = doc.data.subject;
    if (!grouped.has(key)) {
        grouped.set(key, []);
    }
    grouped.get(key)!.push(doc);
}

const subjectList = Array.from(grouped.keys()).sort((a, b) => a.localeCompare(b));
---

{
    subjectList.length === 0 ? (
        <p class="text-on-surface-variant text-center my-8">
            No subjects have been added to this term yet.
        </p>
    ) : (
        <CardGrid>
            {subjectList.map((subjName) => {
                const docsForSubject = grouped.get(subjName)!;
                const firstDoc = docsForSubject[0];
                const href = `${import.meta.env.BASE_URL}/docs/${firstDoc.id.replace(/^docs\//, "")}/`;
                const count = docsForSubject.length;
                const isAi = docsForSubject.some(
                    (doc) => (doc.data as { isAiGenerated?: boolean }).isAiGenerated === true,
                );

                return (
                    <LinkCard
                        title={subjName}
                        description={`${count} document${count > 1 ? "s" : ""}`}
                        href={href}
                    />
                );
            })}
        </CardGrid>
    )
}
