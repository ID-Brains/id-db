---
import { getCollection } from "astro:content";
import { LinkCard, CardGrid } from "@astrojs/starlight/components";

interface Props {
    level: string;
    term: number;
}

const { level, term } = Astro.props;

const allDocs = await getCollection("docs");

const termDocs = allDocs.filter(
    (doc) =>
        doc.data.level === level &&
        doc.data.term === term &&
        !doc.id.endsWith("index") &&
        doc.id !== "docs" &&
        doc.id !== "404",
);

const grouped = new Map<string, typeof termDocs>();
for (const doc of termDocs) {
    const key = doc.data.subject;
    if (!grouped.has(key)) {
        grouped.set(key, []);
    }
    grouped.get(key)!.push(doc);
}

const aiSubjects = new Set<string>();
for (const doc of termDocs) {
    if ((doc.data as { isAiGenerated?: boolean }).isAiGenerated === true) {
        aiSubjects.add(doc.data.subject);
    }
}

const subjectList = Array.from(grouped.keys()).sort((a, b) => a.localeCompare(b));
const sortedSubjects = subjectList.sort((a, b) => {
    const aIsAi = aiSubjects.has(a);
    const bIsAi = aiSubjects.has(b);
    if (aIsAi === bIsAi) return a.localeCompare(b);
    return aIsAi ? 1 : -1;
});
---

{
    sortedSubjects.length === 0 ? (
        <p class="text-on-surface-variant text-center my-8">
            No subjects have been added to this term yet.
        </p>
    ) : (
        <CardGrid>
            {sortedSubjects.map((subjName) => {
                const docsForSubject = grouped.get(subjName)!;
                const isAi = aiSubjects.has(subjName);
                const firstDoc = docsForSubject[0];
                const href = `${import.meta.env.BASE_URL}/${firstDoc.id}/`;
                const count = docsForSubject.length;

                return (
                    <LinkCard
                        title={subjName}
                        description={`${count} document${count > 1 ? "s" : ""}`}
                        href={href}
                    >
                        {isAi && <span class="badge">AI Generated</span>}
                    </LinkCard>
                );
            })}
        </CardGrid>
    )
}