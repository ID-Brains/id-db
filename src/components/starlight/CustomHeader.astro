---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
	config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const page = Astro.props.page ?? Astro.props.entry;
const isAiGenerated = page?.data?.isAiGenerated === true;
---

<header class="my-header">
	<nav class="my-nav">
		<div class="my-brand">
			<SiteTitle />
		</div>

		<div class="my-links">
			<a href={import.meta.env.BASE_URL}>Home</a>
			<a href={`${import.meta.env.BASE_URL}/docs`}>Docs</a>
		</div>

		<div class="my-actions">
			{shouldRenderSearch && <Search class="my-search" />}
			<div class="my-desktop-only"><SocialIcons /></div>
			<div class="my-desktop-only"><ThemeSelect /></div>
			<div class="my-desktop-only"><LanguageSelect /></div>
		</div>
	</nav>
</header>

{isAiGenerated && (
	<div class="my-ai-banner">
		<span class="my-ai-badge">AI Generated</span>
	</div>
)}

<style>
	.my-header {
		height: 100%;
		display: flex;
		align-items: center;
	}

	.my-nav {
		width: 100%;
		display: grid;
		grid-template-columns: auto 1fr auto;
		align-items: center;
		gap: 1rem;
	}

	.my-links {
		display: none;
		justify-content: center;
		gap: 1.25rem;
	}

	.my-links a {
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-weight: 600;
	}

	.my-links a:hover {
		color: var(--sl-color-white);
	}

	.my-actions {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.my-ai-banner {
		margin: 0.75rem 0 0;
		padding-inline: 1.5rem;
	}

	.my-ai-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.25rem 0.625rem;
		border-radius: 999px;
		background: var(--sl-color-accent-low);
		color: var(--sl-color-accent-high);
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.my-desktop-only {
		display: none;
	}

	:global(.my-search button[data-open-modal]) {
		max-width: 15rem;
	}

	@media (min-width: 50rem) {
		.my-links {
			display: flex;
		}

		.my-desktop-only {
			display: flex;
			align-items: center;
		}
	}
</style>
