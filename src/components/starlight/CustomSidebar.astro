---
import DefaultSidebar from "@astrojs/starlight/components/Sidebar.astro";

interface SidebarGroup {
    type: string;
    label: string;
    isLink?: boolean;
}

const { pathname } = Astro.url;
const { sidebar } = Astro.props;

const decodedPathname = decodeURIComponent(pathname);
const pathSegments = decodedPathname.split("/").filter(Boolean);
const currentLevel = pathSegments.find((segment) =>
    /^level-[1-4]$/.test(segment),
);

const filteredSidebar = currentLevel && sidebar
    ? sidebar.filter((group: SidebarGroup) => {
          if (group.type !== "group") return true;

          const normalizedLabel = group.label
              .toLowerCase()
              .replace(/\s+/g, "-");
          return normalizedLabel === currentLevel || group.isLink;
      })
    : sidebar;
---

<DefaultSidebar {...Astro.props} sidebar={filteredSidebar} />
